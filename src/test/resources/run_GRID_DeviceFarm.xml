<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="orangeHRM - User" parallel="tests" thread-count="2">
    <listeners>
<!--            <listener class-name="repo"/>-->
    </listeners>
    <parameter name="environment" value="dev"/>

    <test name="Run on Chrome - Windows">
        <parameter name="platformName" value="Windows"/>
        <parameter name="browserName" value="chrome"/>
        <parameter name="browserVersion" value="latest"/>
        <classes>
            <class name="com.orangehrm.Level_28_Cloud_DeviceFarm"/>
        </classes>
    </test>

    <test name="Run on Firefox - Windows">
        <parameter name="platformName" value="Windows"/>
        <parameter name="browserName" value="firefox"/>
        <parameter name="browserVersion" value="latest"/>
        <classes>
            <class name="com.orangehrm.Level_28_Cloud_DeviceFarm"/>
        </classes>
    </test>

</suite>