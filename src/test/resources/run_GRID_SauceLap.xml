<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="orangeHRM - User" parallel="tests" thread-count="2">
    <listeners>
<!--            <listener class-name="repo"/>-->
    </listeners>
    <parameter name="environment" value="dev"/>

    <test name="Run on Chrome - Windows">
        <parameter name="platformName" value="Windows 11"/>
        <parameter name="browserName" value="Chrome"/>
        <parameter name="browserVersion" value="146.0"/>
        <classes>
            <class name="com.orangehrm.Level_28_Cloud_SauceLap"/>
        </classes>
    </test>

    <test name="Run on Firefox - Windows">
        <parameter name="platformName" value="Windows 10"/>
        <parameter name="browserName" value="Firefox"/>
        <parameter name="browserVersion" value="136.0"/>
        <classes>
            <class name="com.orangehrm.Level_28_Cloud_SauceLap"/>
        </classes>
    </test>

</suite>